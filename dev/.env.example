APP_ENV=local
APP_MODE=mock
BUILD_LABEL=local

AZURE_AI_ENDPOINT=
AZURE_REALTIME_DEPLOYMENT=gpt-realtime-1-5
AZURE_TRANSCRIPTION_DEPLOYMENT=gpt-realtime-whisper
AZURE_VOICELIVE_ENDPOINT=
AZURE_VOICELIVE_MODEL=gpt-realtime-1.5
AZURE_VOICELIVE_TRANSCRIPTION_MODEL=azure-speech

AZURE_STORAGE_ACCOUNT_URL=
